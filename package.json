{
  "name": "pokejumper-desktop",
  "version": "1.0.1",
  "author": "Your Name",
  "description": "Desktop client for pokejumper.org",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --publish never"
  },
  "build": {
    "appId": "com.yourdomain.app",
    "productName": "Pokejumper",
    "files": [
      "src/**/*"
    ],
    "win": {
      "target": "nsis"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
